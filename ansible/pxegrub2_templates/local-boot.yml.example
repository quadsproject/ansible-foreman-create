# Set the "Local boot PXEGrub2 template" global setting in Foreman
# (Administer → Settings → Provisioning → Local boot PXEGrub2 template).
# Copy this file to local-boot.yml and set the template name.
#
# The template must already exist in Foreman — either a built-in template or
# a custom template uploaded from this directory. The task verifies the template
# exists with kind PXEGrub2 before applying the setting, and prints a warning
# (without failing) if the named template is not found.
#
# Run on the Foreman host to see the current value:
#   hammer settings list --search "local_boot"
#
# Run on the Foreman host to list available PXEGrub2 templates:
#   hammer template list --per-page 100 | grep PXEGrub2

template: "PXEGrub2 default local boot"
